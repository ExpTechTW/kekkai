#!/bin/sh
# /etc/update-motd.d/98-kekkai — installed by kekkai.sh.
#
# Reads the state file kekkai-agent drops when its background
# auto-update loop hits an error. Keeps the MOTD quiet in the
# happy path: if the file doesn't exist, exit 0 silently so the
# next motd fragment runs immediately.
#
# Shown to every new SSH / console login. Does NOT wake existing
# sessions; it is a passive on-login notification, not a broadcast.

set -eu

ERR=/var/lib/kekkai/auto_update_error.txt
[ -f "$ERR" ] || exit 0

# ANSI colour is safe here: /etc/update-motd.d fragments run with
# TERM already set by the login shell. Tolerate NO_COLOR just in
# case a scripted SSH client sets it.
if [ -n "${NO_COLOR:-}" ]; then
    YELLOW=""; DIM=""; RESET=""
else
    YELLOW=$(printf '\033[1;33m')
    DIM=$(printf '\033[2m')
    RESET=$(printf '\033[0m')
fi

echo
printf '%s⚠  kekkai auto-update failed%s\n' "$YELLOW" "$RESET"
grep -E '^(kind|target_version|timestamp|last_error)=' "$ERR" 2>/dev/null \
    | sed 's/^/   /' \
    | while IFS= read -r line; do
        printf '%s%s%s\n' "$DIM" "$line" "$RESET"
    done
printf '%s   run: sudo kekkai doctor%s\n' "$DIM" "$RESET"
printf '%s   clear: sudo rm %s%s\n' "$DIM" "$ERR" "$RESET"
echo
